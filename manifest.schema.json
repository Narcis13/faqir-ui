{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faqir.dev/manifest.schema.json",
  "schema_version": "1.0.0",
  "title": "Faqir manifest",
  "description": "The machine-readable contract shipped beside every Faqir component and theme. A file validates as either a component manifest (`<name>.manifest.json`) or a theme manifest (`<name>.theme.json`). Versioned via `schema_version`; the 1.0-01 freeze builds on this schema.",
  "oneOf": [
    { "$ref": "#/definitions/componentManifest" },
    { "$ref": "#/definitions/themeManifest" }
  ],
  "definitions": {
    "componentManifest": {
      "type": "object",
      "description": "A primitive, recipe, pattern, or scaffold component manifest.",
      "required": [
        "name",
        "version",
        "kind",
        "category",
        "description",
        "anatomy",
        "slots",
        "variants",
        "states",
        "a11y",
        "tokens_used",
        "templates",
        "safe_transforms",
        "unsafe_transforms",
        "composition",
        "files",
        "tests"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": ["primitive", "recipe", "pattern", "scaffold"]
        },
        "category": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "aliases": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "changes": {
          "type": "array",
          "items": { "$ref": "#/definitions/change" }
        },
        "anatomy": { "$ref": "#/definitions/anatomy" },
        "slots": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/slot" }
        },
        "variants": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/variant" }
        },
        "states": {
          "type": "object",
          "additionalProperties": { "type": "object" }
        },
        "a11y": { "type": "object" },
        "tokens_used": {
          "type": "array",
          "items": { "type": "string" }
        },
        "templates": { "$ref": "#/definitions/templates" },
        "safe_transforms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "unsafe_transforms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "composition": { "$ref": "#/definitions/composition" },
        "files": { "$ref": "#/definitions/files" },
        "tests": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "anatomy": {
      "type": "object",
      "required": ["tag", "selector"],
      "properties": {
        "tag": { "type": "string" },
        "selector": { "type": "string" },
        "content_model": {
          "type": "string",
          "enum": ["inline", "block", "slots", "text", "empty"]
        }
      }
    },
    "slot": {
      "type": "object",
      "required": ["selector", "required"],
      "properties": {
        "selector": { "type": "string" },
        "required": { "type": "boolean" },
        "tag_hint": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "variant": {
      "type": "object",
      "required": ["values", "default", "attr"],
      "properties": {
        "values": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "default": { "type": "string" },
        "attr": { "type": "string" },
        "applied_to": { "type": "string" }
      }
    },
    "change": {
      "type": "object",
      "description": "One changelog entry (task 0.5-04). Consumed by `faqir upgrade`.",
      "required": ["version", "note", "breaking"],
      "properties": {
        "version": { "type": "string", "minLength": 1 },
        "note": { "type": "string", "minLength": 1 },
        "breaking": { "type": "boolean" }
      }
    },
    "templates": {
      "type": "object",
      "description": "Named HTML templates. Most components ship an `html` template; some ship only variant-specific templates (`html_group`, `html_single`, …). Every value is an HTML string.",
      "minProperties": 1,
      "additionalProperties": { "type": "string" }
    },
    "composition": {
      "type": "object",
      "required": ["contains", "used_in"],
      "properties": {
        "contains": { "type": "array", "items": { "type": "string" } },
        "used_in": { "type": "array", "items": { "type": "string" } }
      }
    },
    "files": {
      "type": "object",
      "required": ["html", "css", "manifest"],
      "properties": {
        "html": { "type": "string" },
        "css": { "type": "string" },
        "js": { "type": "string" },
        "manifest": { "type": "string" }
      }
    },
    "themeManifest": {
      "type": "object",
      "description": "A theme descriptor shipped as `<name>.theme.json` beside `<name>.css`.",
      "required": [
        "name",
        "version",
        "mood",
        "scheme",
        "dark_mode",
        "tokens_overridden",
        "tokens_inherited",
        "pairs_with",
        "preview"
      ],
      "properties": {
        "$schema": { "type": "string" },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "mood": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "scheme": {
          "type": "string",
          "enum": ["light", "dark", "both"]
        },
        "dark_mode": {
          "type": "string",
          "enum": ["native", "none"]
        },
        "tokens_overridden": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "tokens_inherited": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "pairs_with": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "preview": { "type": "string", "minLength": 1 }
      }
    }
  }
}
