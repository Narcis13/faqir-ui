{
  "name": "date-picker",
  "version": "1.1.0",
  "kind": "recipe",
  "category": "forms",
  "description": "Date input with calendar dropdown for date selection — the month grid is the nested `calendar` recipe",

  "anatomy": {
    "tag": "div",
    "selector": "[data-ui='date-picker']",
    "content_model": "slots"
  },

  "slots": {
    "trigger": {
      "selector": "[data-part='trigger']",
      "required": true,
      "tag_hint": "div",
      "description": "Clickable area containing input and icon"
    },
    "input": {
      "selector": "[data-part='input']",
      "required": true,
      "tag_hint": "input",
      "description": "Text input displaying the selected date"
    },
    "icon": {
      "selector": "[data-part='icon']",
      "required": false,
      "tag_hint": "span",
      "description": "Decorative calendar glyph inside the trigger (aria-hidden)"
    },
    "calendar": {
      "selector": "[data-part='calendar']",
      "required": true,
      "tag_hint": "div",
      "description": "Calendar dropdown container. Canonically nests a [data-ui='calendar'] recipe that owns the header, month navigation and day grid; legacy markup with those parts placed directly inside this container keeps working"
    }
  },

  "variants": {
    "size": {
      "values": ["sm", "md", "lg"],
      "default": "md",
      "attr": "data-size",
      "applied_to": "root"
    }
  },

  "states": {
    "closed": { "attr": "data-state=\"closed\"", "default": true },
    "open": { "attr": "data-state=\"open\"" }
  },

  "props": {
    "value": { "type": "string", "default": "", "description": "Selected date value" },
    "placeholder": { "type": "string", "default": "Select date", "description": "Input placeholder text" }
  },

  "a11y": {
    "required_attrs": [
      "aria-haspopup=\"dialog\" on input",
      "aria-expanded on input",
      "role=\"dialog\" and aria-label on the calendar container",
      "role=\"grid\" on the nested calendar grid",
      "aria-label on day buttons with full date",
      "aria-label on nav-prev and nav-next",
      "aria-selected=\"true\" on selected day"
    ],
    "keyboard": {
      "Escape": "close calendar",
      "Enter/Space": "select focused day",
      "ArrowLeft": "focus previous day",
      "ArrowRight": "focus next day",
      "ArrowUp": "focus same day previous week",
      "ArrowDown": "focus same day next week",
      "Home": "focus first day of the week",
      "End": "focus last day of the week",
      "PageUp": "focus same day previous month",
      "PageDown": "focus same day next month"
    }
  },

  "tokens_used": [
    "color-bg", "color-fg", "color-fg-muted",
    "color-border", "color-primary", "color-ring",
    "shadow-lg", "radius-md", "radius-lg",
    "space-1", "space-2", "space-3", "space-4",
    "text-xs", "text-sm",
    "z-dropdown", "duration-fast", "ease-default"
  ],

  "templates": {
    "html": "<div data-ui=\"date-picker\" data-state=\"closed\" data-size=\"{size}\">\n  <div data-part=\"trigger\">\n    <input data-part=\"input\" type=\"text\" placeholder=\"Select a date\" readonly aria-haspopup=\"dialog\" aria-expanded=\"false\" aria-label=\"Choose date\">\n    <span data-part=\"icon\" aria-hidden=\"true\">&#x1F4C5;</span>\n  </div>\n  <div data-part=\"calendar\" role=\"dialog\" aria-label=\"Date picker\" hidden>\n    <div data-ui=\"calendar\" data-size=\"{size}\">\n      <div data-part=\"header\">\n        <button data-part=\"nav-prev\" type=\"button\" aria-label=\"Previous month\">&lsaquo;</button>\n        <span data-part=\"month-label\"></span>\n        <button data-part=\"nav-next\" type=\"button\" aria-label=\"Next month\">&rsaquo;</button>\n      </div>\n      <table data-part=\"grid\" role=\"grid\" aria-label=\"Calendar\">\n        <thead><tr><th>Su</th><th>Mo</th><th>Tu</th><th>We</th><th>Th</th><th>Fr</th><th>Sa</th></tr></thead>\n        <tbody data-part=\"grid-body\"></tbody>\n      </table>\n    </div>\n  </div>\n</div>"
  },

  "safe_transforms": [
    "change-size",
    "customize-date-format",
    "restyle-selected-day",
    "restyle-today-highlight",
    "add-min-max-date",
    "change-first-day-of-week"
  ],

  "unsafe_transforms": [
    "remove-aria-expanded",
    "remove-grid-role",
    "remove-day-aria-labels",
    "remove-keyboard-navigation",
    "remove-outside-click-handler",
    "duplicate-grid-logic-outside-calendar-recipe"
  ],

  "composition": {
    "contains": ["calendar", "button"],
    "used_in": []
  },

  "files": {
    "html": "date-picker.html",
    "css": "date-picker.css",
    "js": "date-picker.js",
    "manifest": "date-picker.manifest.json"
  },

  "tests": [
    "opens-calendar-on-trigger-click",
    "closes-calendar-on-escape",
    "closes-calendar-on-outside-click",
    "selects-date-on-day-click",
    "updates-input-on-selection",
    "closes-after-selection",
    "nav-prev-shows-previous-month",
    "nav-next-shows-next-month",
    "today-is-highlighted",
    "selected-day-has-aria-selected",
    "input-has-aria-expanded",
    "input-has-aria-haspopup",
    "grid-has-role-grid",
    "day-buttons-have-aria-label",
    "arrow-keys-navigate-days",
    "generates-correct-calendar-grid",
    "delegates-grid-to-calendar-recipe",
    "legacy-flat-markup-still-works"
  ]
}
