{
  "$schema": "../../../manifest.schema.json",
  "name": "calendar",
  "version": "1.0.0",
  "kind": "recipe",
  "category": "forms",
  "description": "Standalone month-grid calendar with roving-tabindex keyboard navigation, min/max/disabled dates, and single or range selection — extracted from date-picker so availability grids and range pickers can use it directly",

  "anatomy": {
    "tag": "div",
    "selector": "[data-ui='calendar']",
    "content_model": "slots"
  },

  "slots": {
    "header": {
      "selector": "[data-part='header']",
      "required": false,
      "tag_hint": "div",
      "description": "Row holding the month navigation buttons and the month label"
    },
    "nav-prev": {
      "selector": "[data-part='nav-prev']",
      "required": false,
      "tag_hint": "button",
      "description": "Navigate to previous month; auto-disabled when the whole previous month is before data-min"
    },
    "nav-next": {
      "selector": "[data-part='nav-next']",
      "required": false,
      "tag_hint": "button",
      "description": "Navigate to next month; auto-disabled when the whole next month is after data-max"
    },
    "month-label": {
      "selector": "[data-part='month-label']",
      "required": true,
      "tag_hint": "span",
      "description": "Displays current month and year"
    },
    "grid": {
      "selector": "[data-part='grid']",
      "required": true,
      "tag_hint": "table",
      "description": "Calendar grid with role=grid and an aria-label"
    },
    "grid-body": {
      "selector": "[data-part='grid-body']",
      "required": true,
      "tag_hint": "tbody",
      "description": "Body the controller fills with week rows of day buttons"
    },
    "day": {
      "selector": "[data-part='day']",
      "required": false,
      "tag_hint": "button",
      "description": "Individual day button — generated by the controller, never authored by hand"
    }
  },

  "variants": {
    "size": {
      "values": ["sm", "md", "lg"],
      "default": "md",
      "attr": "data-size",
      "applied_to": "root"
    }
  },

  "states": {
    "range-start": {
      "attr": "data-state=\"range-start\"",
      "applied_to": "day",
      "description": "First endpoint of a range selection (data-mode=\"range\")"
    },
    "in-range": {
      "attr": "data-state=\"in-range\"",
      "applied_to": "day",
      "description": "Day strictly between the selected range endpoints"
    },
    "range-end": {
      "attr": "data-state=\"range-end\"",
      "applied_to": "day",
      "description": "Second endpoint of a range selection"
    }
  },

  "props": {
    "value": { "type": "string", "default": "", "description": "Initial selection: YYYY-MM-DD (single) or YYYY-MM-DD,YYYY-MM-DD (range)" },
    "mode": { "type": "string", "default": "single", "description": "data-mode: single or range selection" },
    "min": { "type": "string", "default": "", "description": "data-min: earliest selectable date (YYYY-MM-DD, inclusive)" },
    "max": { "type": "string", "default": "", "description": "data-max: latest selectable date (YYYY-MM-DD, inclusive)" },
    "disabled-dates": { "type": "string", "default": "", "description": "data-disabled-dates: comma/space separated YYYY-MM-DD dates that cannot be selected" }
  },

  "events": {
    "faqir:calendar-change": {
      "detail_single": "{ date: 'YYYY-MM-DD', dateObj: Date }",
      "detail_range": "{ start, end: 'YYYY-MM-DD', startObj, endObj: Date } — emitted when the range completes",
      "bubbles": true
    }
  },

  "a11y": {
    "required_attrs": [
      "role=\"grid\" on grid",
      "aria-label on grid",
      "aria-label on day buttons with full date",
      "aria-label on nav-prev and nav-next",
      "aria-selected=\"true\" on selected day(s)",
      "aria-disabled=\"true\" on out-of-range or disabled days (kept focusable for the roving tabindex)"
    ],
    "keyboard": {
      "ArrowLeft": "focus previous day",
      "ArrowRight": "focus next day",
      "ArrowUp": "focus same day previous week",
      "ArrowDown": "focus same day next week",
      "Home": "focus first day of the week",
      "End": "focus last day of the week",
      "PageUp": "focus same day previous month",
      "PageDown": "focus same day next month",
      "Shift+PageUp": "focus same day previous year",
      "Shift+PageDown": "focus same day next year",
      "Enter/Space": "select focused day"
    }
  },

  "tokens_used": [
    "color-bg", "color-fg", "color-fg-muted", "color-fg-subtle",
    "color-border", "color-primary", "color-primary-fg",
    "color-primary-subtle", "color-ring",
    "radius-md", "radius-full",
    "space-0", "space-1", "space-2",
    "text-xs", "text-sm", "text-base", "weight-medium",
    "duration-fast", "ease-default"
  ],

  "templates": {
    "html": "<div data-ui=\"calendar\" data-size=\"{size}\">\n  <div data-part=\"header\">\n    <button data-part=\"nav-prev\" type=\"button\" aria-label=\"Previous month\">&lsaquo;</button>\n    <span data-part=\"month-label\"></span>\n    <button data-part=\"nav-next\" type=\"button\" aria-label=\"Next month\">&rsaquo;</button>\n  </div>\n  <table data-part=\"grid\" role=\"grid\" aria-label=\"Calendar\">\n    <thead><tr><th>Su</th><th>Mo</th><th>Tu</th><th>We</th><th>Th</th><th>Fr</th><th>Sa</th></tr></thead>\n    <tbody data-part=\"grid-body\"></tbody>\n  </table>\n</div>"
  },

  "safe_transforms": [
    "change-size",
    "restyle-selected-day",
    "restyle-today-highlight",
    "restyle-range-band",
    "add-min-max-date",
    "add-disabled-dates",
    "change-first-day-of-week"
  ],

  "unsafe_transforms": [
    "remove-grid-role",
    "remove-day-aria-labels",
    "remove-keyboard-navigation",
    "remove-roving-tabindex",
    "hand-author-day-cells"
  ],

  "composition": {
    "contains": [],
    "used_in": ["date-picker"]
  },

  "files": {
    "html": "calendar.html",
    "css": "calendar.css",
    "js": "calendar.js",
    "manifest": "calendar.manifest.json"
  },

  "tests": [
    "generates-correct-calendar-grid",
    "roving-tabindex-single-stop",
    "arrow-keys-navigate-days",
    "arrow-navigation-crosses-month-boundary",
    "home-end-jump-to-week-bounds",
    "pageup-pagedown-navigate-months",
    "shift-pageup-pagedown-navigate-years",
    "enter-space-select-focused-day",
    "click-selects-day",
    "selected-day-has-aria-selected",
    "emits-calendar-change-event",
    "min-max-dates-disabled-and-unselectable",
    "disabled-dates-unselectable",
    "focus-clamped-to-min-max",
    "nav-buttons-disabled-at-bounds",
    "range-start-end-in-range-states",
    "range-restarts-on-earlier-pick",
    "setvalue-getvalue-roundtrip",
    "navigate-api-changes-view",
    "today-is-highlighted",
    "day-buttons-have-aria-label",
    "double-init-returns-same-api"
  ]
}
