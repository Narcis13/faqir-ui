{
  "name": "@faqir-ui/forms",
  "version": "0.1.0",
  "description": "Isomorphic, zero-dependency JSON Schema to audit-clean Faqir form renderer",
  "type": "module",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "faqir",
    "forms",
    "json-schema",
    "html",
    "zero-dependency",
    "isomorphic"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Narcis13/faqir-ui.git",
    "directory": "packages/forms"
  },
  "homepage": "https://github.com/Narcis13/faqir-ui/tree/main/packages/forms#readme",
  "bugs": {
    "url": "https://github.com/Narcis13/faqir-ui/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
