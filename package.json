{
  "name": "faqir-ui-cli",
  "version": "0.2.4",
  "description": "Agent-native UI framework — CLI-distributed, manifest-driven, zero-dependency components",
  "type": "module",
  "exports": {
    ".": "./dist/faqir.mjs"
  },
  "bin": {
    "faqir": "./bin/faqir"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build:cli": "node scripts/build-cli.mjs",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "smoke": "bash scripts/smoke-cli.sh",
    "release": "node scripts/release.mjs",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major",
    "check:package": "npm pack --dry-run",
    "prepublishOnly": "npm run build:cli && npm run check:package"
  },
  "files": [
    "bin",
    "dist",
    "registry",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ui",
    "framework",
    "cli",
    "components",
    "agent-native",
    "html",
    "css",
    "bun"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Narcis13/faqir-ui.git"
  },
  "homepage": "https://github.com/Narcis13/faqir-ui#readme",
  "bugs": {
    "url": "https://github.com/Narcis13/faqir-ui/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.3",
    "@types/bun": "latest",
    "happy-dom": "^20.8.3",
    "typescript": "^5.7.0"
  }
}
